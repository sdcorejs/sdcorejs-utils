{
  "name": "@sdcorejs/utils",
  "version": "1.1.3",
  "description": "Pure TypeScript utility library — models, constants, functions",
  "license": "MIT",
  "homepage": "https://sdcorejs.github.io/sdcorejs-utils",
  "repository": {
    "type": "git",
    "url": "https://github.com/sdcorejs/sdcorejs-utils.git"
  },
  "bugs": {
    "url": "https://github.com/sdcorejs/sdcorejs-utils/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js",
      "require": "./dist/models.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    },
    "./fns": {
      "types": "./dist/fns.d.ts",
      "import": "./dist/fns.js",
      "require": "./dist/fns.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jsdom": "^28.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.1.1",
    "rxjs": "^7.8.2",
    "tsup": "^8.0.0",
    "typescript": "~5.7.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
